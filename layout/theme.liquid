<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {%- if template.name == 'index' -%}
    <title>إرث IRTH — تمور المدينة الفاخرة · Luxury Dates from Madinah</title>
    <meta name="description" content="إرث — تمور عجوة ومجول من قلب المدينة المنورة. منتجات غذائية فاخرة للهدايا والجملة. نشحن للخليج ومصر وأوروبا وأفريقيا. IRTH: premium Ajwa & Medjool dates, corporate gifts, B2B wholesale.">
  {%- elsif template.name == 'product' -%}
    <title>{{ product.title }} | إرث IRTH</title>
    <meta name="description" content="{{ product.description | strip_html | truncate: 160 | escape }}">
  {%- elsif template.name == 'collection' -%}
    <title>{{ collection.title }} | تسوق — إرث IRTH</title>
    <meta name="description" content="{{ collection.description | strip_html | default: collection.title | append: ' — تمور المدينة الفاخرة من إرث.' | truncate: 160 | escape }}">
  {%- elsif template.name == 'article' -%}
    <title>{{ article.title }} | مجلة إرث</title>
    <meta name="description" content="{{ article.excerpt_or_content | strip_html | truncate: 160 | escape }}">
  {%- else -%}
    <title>{{ page_title }} | إرث IRTH</title>
    {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}
  {%- endif -%}

  <!-- Canonical -->
  {%- if canonical_url != blank -%}
    <link rel="canonical" href="{{ canonical_url }}">
  {%- endif -%}

  <!-- Hreflang -->
  {% render 'irth-hreflang' %}

  <!-- Open Graph -->
  <meta property="og:site_name" content="إرث IRTH">
  <meta property="og:locale" content="ar_SA">
  {%- if template.name == 'product' -%}
    <meta property="og:type" content="product">
    <meta property="og:title" content="{{ product.title | escape }} | إرث">
    <meta property="og:description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
    <meta property="og:image" content="{{ product.featured_image | image_url: width: 1200, height: 630, crop: 'center' }}">
    <meta property="og:url" content="{{ canonical_url }}">
  {%- elsif template.name == 'index' -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="إرث IRTH — تمور المدينة الفاخرة · Luxury Dates from Madinah">
    <meta property="og:description" content="تمور عجوة ومجول من المدينة المنورة. هدايا فاخرة وتوريد بالجملة. Premium Ajwa dates, B2B wholesale.">
    <meta property="og:image" content="{{ 'og-home.jpg' | asset_url }}">
    <meta property="og:url" content="{{ shop.url }}">
  {%- else -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ page_title | escape }} | إرث">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:image" content="{{ 'og-home.jpg' | asset_url }}">
  {%- endif -%}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }} | إرث IRTH">
  <meta name="twitter:image" content="{{ 'og-home.jpg' | asset_url }}">

  <!-- Geo -->
  <meta name="geo.region" content="SA-MD">
  <meta name="geo.placename" content="Al Madinah Al Munawwarah, Saudi Arabia">
  <meta name="geo.position" content="24.5247;39.5692">
  <meta name="ICBM" content="24.5247, 39.5692">

  <!-- Robots -->
  {%- if template.name == 'search' or template.name == 'cart' or template.name == '404' -%}
    <meta name="robots" content="noindex, follow">
  {%- else -%}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">
  {%- endif -%}

  <!-- Schema JSON-LD -->
  {% render 'irth-organization-schema' %}
  {%- if template.name == 'product' -%}{% render 'irth-product-schema' %}{%- endif -%}
  {%- if template.name != 'index' -%}{% render 'irth-breadcrumb-schema' %}{%- endif -%}
  {% render 'irth-faq-schema' %}

  <!-- Favicons -->
  <link rel="icon" href="{{ 'favicon.ico' | asset_url }}" sizes="any">
  <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}">
  <link rel="icon" type="image/png" sizes="96x96" href="{{ 'favicon-96x96.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ 'favicon-32.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ 'favicon-16.png' | asset_url }}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ 'apple-touch-icon.png' | asset_url }}">
  <link rel="manifest" href="{{ 'site.webmanifest' | asset_url }}">
  <meta name="theme-color" content="#0E2B22">

  <!-- GA4 -->
  {%- if settings.ga4_measurement_id != blank -%}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_measurement_id }}"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ settings.ga4_measurement_id }}');</script>
  {%- endif -%}

  {{ content_for_header }}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,700&family=Noto+Naskh+Arabic:wght@400;500;700&display=swap" rel="stylesheet">

  <!-- Video preloads (home only) -->
  {%- if template.name == 'index' -%}
  <link rel="preload" as="video" href="{{ 'intro-mobile.mp4' | asset_url }}"  media="(max-width: 768px)"  type="video/mp4">
  <link rel="preload" as="video" href="{{ 'intro-desktop.mp4' | asset_url }}" media="(min-width: 769px)" type="video/mp4">
  {%- endif -%}

  <!-- Shopify prefers-reduced-motion -->
  <style>
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; }
    }
  </style>

  {{ 'irth-main.css' | asset_url | stylesheet_tag }}

  {%- if settings.custom_css != blank -%}
    <style>{{ settings.custom_css }}</style>
  {%- endif -%}
</head>
<body class="template-{{ template.name }}{% if template.suffix != blank %}-{{ template.suffix }}{% endif %}">

  <!-- Inject asset base URLs for JS -->
  <script>
    window.IRTH_FRAME_BASE = "{{ 'irth_0001.jpg' | asset_url | split: 'irth_0001.jpg' | first }}";
    window.IRTH_ASSETS = {
      heroDesktop:      "{{ 'hero-desktop.mp4'      | asset_url }}",
      heroMobile:       "{{ 'hero-mobile.mp4'       | asset_url }}",
      introDesktop:     "{{ 'intro-desktop.mp4'     | asset_url }}",
      introMobile:      "{{ 'intro-mobile.mp4'      | asset_url }}",
      transDesktop:     "{{ 'transition-desktop.mp4'| asset_url }}",
      transMobile:      "{{ 'transition-mobile.mp4' | asset_url }}"
    };
  </script>

  <main id="main" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Ambient audio (home only) -->
  {%- if template.name == 'index' -%}
    {% render 'ambient-audio' %}
  {%- endif -%}

  <!-- GSAP + Lenis + main (all served from Shopify CDN, defer preserves order) -->
  <script src="{{ 'gsap.min.js' | asset_url }}" defer></script>
  <script src="{{ 'ScrollTrigger.min.js' | asset_url }}" defer></script>
  <script src="{{ 'lenis.min.js' | asset_url }}" defer></script>
  <script src="{{ 'irth-main.js' | asset_url }}" defer></script>

</body>
</html>
