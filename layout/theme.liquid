<!DOCTYPE html>
<html lang="{{ request.locale.iso_code | default: 'en' }}" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>
    {%- if template.name == 'index' -%}
      {{ shop.name }}{% if shop.description != blank %} — {{ shop.description }}{% endif %}
    {%- else -%}
      {{ page_title }} | {{ shop.name }}
    {%- endif -%}
  </title>

  <meta name="description" content="{{ page_description | default: shop.description | escape }}">

  {%- if canonical_url != blank -%}
    <link rel="canonical" href="{{ canonical_url }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,700&family=Noto+Naskh+Arabic:wght@400;500;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- if settings.custom_css != blank -%}
    <style>{{ settings.custom_css }}</style>
  {%- endif -%}
</head>
<body class="template-{{ template.name }}{% if template.suffix != blank %}-{{ template.suffix }}{% endif %}">

  {%- render 'cursor' -%}
  <div class="noise" aria-hidden="true"></div>
  <div id="prog" aria-hidden="true"></div>
  <div id="veil" aria-hidden="true"></div>

  {%- section 'header' -%}

  <main id="main" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- GSAP + Lenis (pin to exact versions for stability) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/lenis@1.1.20/dist/lenis.min.js" crossorigin="anonymous"></script>
  {{ 'theme.js' | asset_url | script_tag }}

</body>
</html>
