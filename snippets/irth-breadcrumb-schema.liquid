{% comment %}
  IRTH — BreadcrumbList JSON-LD
  Fires on collection, product, and article pages.
  Called from theme.liquid <head>.
{% endcomment %}

{% unless template.name == 'index' or template.name == 'page' or template.name == 'cart' or template.name == 'checkout' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "الرئيسية — Home",
      "item": "https://irth-house.com"
    }
    {% if template.name == 'collection' %},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | escape | json }},
      "item": {{ canonical_url | json }}
    }
    {% endif %}
    {% if template.name == 'product' %}
      {% assign _col = product.collections.first %}
      {% if _col %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ _col.title | escape | json }},
        "item": {{ shop.url | append: '/collections/' | append: _col.handle | json }}
      },{
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | escape | json }},
        "item": {{ canonical_url | json }}
      }
      {% else %},{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | escape | json }},
        "item": {{ canonical_url | json }}
      }
      {% endif %}
    {% endif %}
    {% if template.name == 'article' %},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | escape | json }},
      "item": {{ shop.url | append: '/blogs/' | append: blog.handle | json }}
    },{
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | escape | json }},
      "item": {{ canonical_url | json }}
    }
    {% endif %}
  ]
}
</script>
{% endunless %}
