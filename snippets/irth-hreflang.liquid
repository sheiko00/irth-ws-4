{% comment %}
  IRTH — hreflang tags
  Single-store bilingual (AR/EN) setup.
  When Shopify Markets activates for Gulf/International, replace with market URLs.
{% endcomment %}
<link rel="alternate" hreflang="ar"        href="{{ canonical_url }}">
<link rel="alternate" hreflang="ar-EG"     href="{{ canonical_url }}">
<link rel="alternate" hreflang="ar-SA"     href="{{ canonical_url }}">
<link rel="alternate" hreflang="ar-AE"     href="{{ canonical_url }}">
<link rel="alternate" hreflang="en"        href="{{ canonical_url }}">
<link rel="alternate" hreflang="en-GB"     href="{{ canonical_url }}">
<link rel="alternate" hreflang="en-US"     href="{{ canonical_url }}">
<link rel="alternate" hreflang="x-default" href="{{ canonical_url }}">
