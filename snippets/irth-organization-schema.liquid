{% if template.name == 'index' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "IRTH — إرث",
  "alternateName": ["إرث", "IRTH House", "IRTH Madina", "irth-house"],
  "url": "https://irth-house.com",
  "logo": "https://irth-house.com/cdn/shop/files/IRTH_logo.png",
  "description": "IRTH is a luxury Islamic heritage brand inspired by Madinah Al-Munawwarah. We offer authentic dates, Madinah herbs, misbahas, prayer rugs, fragrances, and luxury gift boxes — shipped to Egypt, the Gulf, and worldwide.",
  "foundingDate": "2025",
  "foundingLocation": {
    "@type": "Place",
    "name": "New Cairo, Egypt"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "New Cairo",
    "addressRegion": "Cairo",
    "addressCountry": "EG"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "hello@irth-house.com",
    "availableLanguage": ["Arabic", "English"],
    "areaServed": ["EG", "SA", "AE", "GB", "US"]
  },
  "sameAs": [
    "https://www.instagram.com/irthmadina",
    "https://www.tiktok.com/@irthmadina",
    "https://www.facebook.com/irthmadina"
  ],
  "knowsAbout": [
    "Madinah Al-Munawwarah",
    "Islamic heritage products",
    "Ajwa dates",
    "Madinah herbs",
    "Arabic luxury gifts",
    "Prophetic medicine"
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "IRTH — إرث",
  "url": "https://irth-house.com",
  "inLanguage": ["ar", "en"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://irth-house.com/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "IRTH — إرث",
  "image": "https://irth-house.com/cdn/shop/files/IRTH_logo.png",
  "url": "https://irth-house.com",
  "email": "hello@irth-house.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "New Cairo",
    "addressLocality": "Cairo",
    "addressRegion": "Cairo Governorate",
    "postalCode": "11835",
    "addressCountry": "EG"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 30.0074,
    "longitude": 31.4913
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday"],
    "opens": "09:00",
    "closes": "22:00"
  },
  "priceRange": "EGP 250 – EGP 7500",
  "hasMap": "https://maps.google.com/?q=New+Cairo+Egypt",
  "sameAs": [
    "https://www.instagram.com/irthmadina",
    "https://www.tiktok.com/@irthmadina"
  ]
}
</script>
{% endif %}
