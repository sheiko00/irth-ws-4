[
  {
    "name": "theme_info",
    "theme_name": "IRTH",
    "theme_version": "1.0.0",
    "theme_author": "IRTH Studio",
    "theme_documentation_url": "https://www.irthmadina.com",
    "theme_support_url": "https://www.irthmadina.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_sand",
        "label": "Sand (Background)",
        "default": "#E9E2D5"
      },
      {
        "type": "color",
        "id": "color_ink",
        "label": "Ink (Text)",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Heritage Gold",
        "default": "#C9A86A"
      },
      {
        "type": "color",
        "id": "color_madinah",
        "label": "Madinah Green",
        "default": "#0E2B22"
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width (px)",
        "min": 40,
        "max": 300,
        "step": 4,
        "default": 80
      }
    ]
  },
  {
    "name": "Entry Screen",
    "settings": [
      {
        "type": "checkbox",
        "id": "entry_screen_enabled",
        "label": "Show entry screen",
        "default": true
      },
      {
        "type": "text",
        "id": "entry_tagline_ar",
        "label": "Entry tagline (Arabic)",
        "default": "تمر فاخر من قلب الجزيرة العربية"
      },
      {
        "type": "text",
        "id": "entry_tagline_en",
        "label": "Entry tagline (English)",
        "default": "Premium dates from the heart of Arabia"
      }
    ]
  },
  {
    "name": "Social Links",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_linkedin",
        "label": "LinkedIn URL"
      },
      {
        "type": "url",
        "id": "social_whatsapp",
        "label": "WhatsApp URL"
      }
    ]
  },
  {
    "name": "Contact",
    "settings": [
      {
        "type": "text",
        "id": "contact_email",
        "label": "Contact email",
        "default": "hello@irthmadina.com"
      },
      {
        "type": "text",
        "id": "contact_phone",
        "label": "Contact phone"
      }
    ]
  },
  {
    "name": "SEO & Analytics",
    "settings": [
      {
        "type": "header",
        "content": "Google Search Console"
      },
      {
        "type": "text",
        "id": "gsc_verification",
        "label": "GSC verification code",
        "info": "Paste only the content= value from the meta tag Google provides. Example: abc123XYZ789"
      },
      {
        "type": "header",
        "content": "Google Analytics 4"
      },
      {
        "type": "text",
        "id": "ga4_measurement_id",
        "label": "GA4 Measurement ID",
        "info": "Format: G-XXXXXXXXXX. Leave blank if using Google Tag Manager."
      }
    ]
  },
  {
    "name": "Custom CSS",
    "settings": [
      {
        "type": "textarea",
        "id": "custom_css",
        "label": "Custom CSS"
      }
    ]
  }
]
