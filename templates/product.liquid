{%- liquid
  assign product_ar_name = product.metafields.irth.name_ar.value | default: product.title
  assign product_ar_desc = product.metafields.irth.desc_ar.value | default: ''
  assign product_origin  = product.metafields.irth.origin.value  | default: ''
  assign product_weight  = product.metafields.irth.weight.value  | default: ''
  assign first_image = product.featured_image
-%}

<div class="product-page">

  <div class="product-layout">

    {%- comment -%} ── Gallery ─────────────────────────────── {%- endcomment -%}
    <div class="product-gallery">
      {%- if product.images.size > 0 -%}
        <div class="product-gallery-main parallax-wrap">
          <img
            id="product-main-img"
            class="product-main-img parallax-img"
            src="{{ product.featured_image | image_url: width: 800 }}"
            srcset="
              {{ product.featured_image | image_url: width: 400 }} 400w,
              {{ product.featured_image | image_url: width: 800 }} 800w,
              {{ product.featured_image | image_url: width: 1200 }} 1200w,
              {{ product.featured_image | image_url: width: 1600 }} 1600w
            "
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 600px"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="800"
            height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
            loading="eager"
            fetchpriority="high"
          >
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-thumbs" role="list">
            {%- for image in product.images limit: 5 -%}
              <button
                class="product-thumb{% if forloop.first %} product-thumb--active{% endif %}"
                data-img-src="{{ image | image_url: width: 800 }}"
                data-img-srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1600 }} 1600w"
                data-img-alt="{{ image.alt | escape }}"
                aria-label="Image {{ forloop.index }}"
                role="listitem"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | escape }}"
                  width="120"
                  height="{{ 120 | divided_by: image.aspect_ratio | round }}"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- comment -%} ── Info ─────────────────────────────────── {%- endcomment -%}
    <div class="product-info">

      <a href="{{ routes.collections_url }}" class="product-back nav-veil-link" aria-label="Back to collection">
        ← <span lang="ar">العودة للمجموعة</span>
      </a>

      <h1 class="product-title-ar sec-title" lang="ar" dir="rtl">{{ product_ar_name }}</h1>
      <h2 class="product-title-en">{{ product.title }}</h2>

      {%- if product_origin != blank -%}
        <span class="product-origin fade-up">{{ product_origin }}</span>
      {%- endif -%}

      <div class="product-price fade-up">
        {%- if product.compare_at_price > product.price -%}
          <s class="product-price-compare">{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="product-price-current">{{ product.price | money }}</span>
      </div>

      {%- if product_ar_desc != blank -%}
        <p class="product-desc fade-up" lang="ar" dir="rtl">{{ product_ar_desc }}</p>
      {%- endif -%}

      {%- if product.description != blank -%}
        <div class="product-desc-html fade-up">{{ product.description }}</div>
      {%- endif -%}

      {%- comment -%} Variant / weight selectors {%- endcomment -%}
      {%- if product.variants.size > 1 -%}
        <div class="product-variants fade-up">
          {%- for variant in product.variants -%}
            <button
              class="product-variant-btn{% if variant == product.selected_or_first_available_variant %} active{% endif %}"
              data-variant-id="{{ variant.id }}"
              {% unless variant.available %}disabled aria-disabled="true"{% endunless %}
            >
              {{ variant.title }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Add to cart form {%- endcomment -%}
      {%- form 'product', product, id: 'product-form', class: 'product-form fade-up' -%}
        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="product-qty-row">
          <label for="product-qty" class="product-qty-label" lang="ar" dir="rtl">الكمية</label>
          <div class="product-qty-ctrl">
            <button type="button" class="qty-btn qty-minus" aria-label="Decrease quantity">−</button>
            <input
              id="product-qty"
              type="number"
              name="quantity"
              value="1"
              min="1"
              class="qty-input"
              aria-label="Quantity"
            >
            <button type="button" class="qty-btn qty-plus" aria-label="Increase quantity">+</button>
          </div>
        </div>

        <button
          type="submit"
          class="product-atc-btn mag-btn"
          {% unless product.available %}disabled aria-disabled="true"{% endunless %}
          lang="ar"
          dir="rtl"
        >
          {%- if product.available -%}
            {{ 'products.product.add_to_cart' | t | default: 'أضف للسلة' }}
          {%- else -%}
            {{ 'products.product.sold_out' | t | default: 'نفذت الكمية' }}
          {%- endif -%}
        </button>

        {%- if product_weight != blank -%}
          <span class="product-weight fade-up" lang="ar" dir="rtl">الوزن: {{ product_weight }}</span>
        {%- endif -%}
      {%- endform -%}

    </div>
  </div>

</div>

<script>
(function () {
  // Thumbnail switcher
  document.querySelectorAll('.product-thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      const mainImg = document.getElementById('product-main-img');
      if (mainImg) {
        mainImg.src = btn.dataset.imgSrc;
        if (btn.dataset.imgSrcset) mainImg.srcset = btn.dataset.imgSrcset;
        mainImg.alt = btn.dataset.imgAlt;
      }
      document.querySelectorAll('.product-thumb').forEach(b => b.classList.remove('product-thumb--active'));
      btn.classList.add('product-thumb--active');
    });
  });

  // Quantity +/−
  const qtyInput = document.querySelector('.qty-input');
  document.querySelector('.qty-plus')?.addEventListener('click', () => {
    if (qtyInput) qtyInput.value = parseInt(qtyInput.value || 1) + 1;
  });
  document.querySelector('.qty-minus')?.addEventListener('click', () => {
    if (qtyInput) qtyInput.value = Math.max(1, parseInt(qtyInput.value || 1) - 1);
  });

  // Variant switcher
  document.querySelectorAll('.product-variant-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.product-variant-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const variantIdInput = document.getElementById('variant-id');
      if (variantIdInput) variantIdInput.value = btn.dataset.variantId;
    });
  });
})();
</script>
