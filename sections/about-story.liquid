<!-- ══ ABOUT — IRTH BRAND STORY ══ -->

<!-- Hero -->
<div class="about-hero">
  <div class="about-hero-content">
    <div class="about-hero-eyebrow">— Our Story · قصتنا</div>
    <h1 class="about-hero-title">
      {{ section.settings.hero_title | default: 'Heritage of the Pure' }}
    </h1>
    <p class="about-hero-sub" lang="ar" dir="rtl">
      {{ section.settings.hero_sub | default: 'إرث ليس مجرد علامة تجارية — إنه التزام بإعادة ما أعطته الأرض بكرم وأمانة.' }}
    </p>
  </div>
</div>

<!-- Story — image + text -->
<div class="about-story-section">
  <div class="about-story-img">
    {%- if section.settings.story_image != blank -%}
      <img src="{{ section.settings.story_image | image_url: width: 1200 }}" alt="" width="1200" height="1500">
    {%- else -%}
      <img src="{{ 'dates-cream-linen.png' | asset_url }}" alt="" width="800" height="1000">
    {%- endif -%}
    <div class="about-story-img-overlay"></div>
    <div class="about-story-img-text" lang="ar" dir="rtl">
      {{ section.settings.img_quote | default: '"نبحث عن الأصل في كل حبّة، وعن الصدق في كل مصدر"' }}
    </div>
  </div>
  <div class="about-story-body">
    <div class="about-story-eyebrow">01 — Our Origin · أصلنا</div>
    <h2 class="about-story-heading" lang="ar" dir="rtl">
      {{ section.settings.story_heading | default: 'ولدنا من رحم <em>التراث</em>' }}
    </h2>
    <p class="about-story-text" lang="ar" dir="rtl">
      {{ section.settings.story_text_1 | default: 'إرث بدأ من سؤال بسيط: لماذا يصعب إيجاد منتجات غذائية فاخرة بأصول حقيقية موثّقة؟ في عالم ملئ بالتقليد والإضافات، قررنا أن نكون مختلفين — أن نبحث عن الأجود في مصادره الأصيلة، ونقدّمه بالقدر الذي يستحقه.' }}
    </p>
    <blockquote class="about-story-quote">
      {{ section.settings.story_quote | default: 'نختار الصبر على السرعة، والمصدر على الاختصار.' }}
    </blockquote>
    <p class="about-story-text" lang="ar" dir="rtl">
      {{ section.settings.story_text_2 | default: 'من تمور العوالي في المدينة المنورة، إلى عسل حضرموت، وزيتون فلسطين، وعود آسيا — كل منتج في إرث يمثّل رحلة بحث عن النقاء في أصله الحقيقي.' }}
    </p>
  </div>
</div>

<!-- Numbers -->
<div class="about-numbers">
  <div class="about-num-item">
    <div class="about-num-val">{{ section.settings.num1_val | default: '12' }}<span class="about-num-suffix">+</span></div>
    <div class="about-num-ar">{{ section.settings.num1_ar | default: 'منتج فاخر' }}</div>
    <div class="about-num-en">{{ section.settings.num1_en | default: 'Premium Products' }}</div>
  </div>
  <div class="about-num-item">
    <div class="about-num-val">{{ section.settings.num2_val | default: '8' }}</div>
    <div class="about-num-ar">{{ section.settings.num2_ar | default: 'دول مصدر' }}</div>
    <div class="about-num-en">{{ section.settings.num2_en | default: 'Countries of Origin' }}</div>
  </div>
  <div class="about-num-item">
    <div class="about-num-val">{{ section.settings.num3_val | default: '100' }}<span class="about-num-suffix">%</span></div>
    <div class="about-num-ar">{{ section.settings.num3_ar | default: 'طبيعي' }}</div>
    <div class="about-num-en">{{ section.settings.num3_en | default: 'Natural & Pure' }}</div>
  </div>
  <div class="about-num-item">
    <div class="about-num-val">{{ section.settings.num4_val | default: '3' }}</div>
    <div class="about-num-ar">{{ section.settings.num4_ar | default: 'أسواق دولية' }}</div>
    <div class="about-num-en">{{ section.settings.num4_en | default: 'Global Markets' }}</div>
  </div>
</div>

<!-- Values -->
<div class="about-values">
  <div class="about-values-eyebrow">02 — Our Pillars · قيمنا</div>
  <h2 class="about-values-title" lang="ar" dir="rtl">{{ section.settings.values_title | default: 'ما نؤمن به' }}</h2>
  <div class="about-vals-grid">
    <div class="about-val">
      <span class="about-val-num">01</span>
      <div class="about-val-ar">المصدر</div>
      <div class="about-val-en">Pure Origins</div>
      <div class="about-val-desc">Every ingredient selected at its source — no additives, no compromise. We visit every farm ourselves.</div>
    </div>
    <div class="about-val">
      <span class="about-val-num">02</span>
      <div class="about-val-ar">الجودة</div>
      <div class="about-val-en">Deep Heritage</div>
      <div class="about-val-desc">Rooted in centuries of Arab culinary tradition — each product carries memory. We don't sell what we wouldn't serve at our own table.</div>
    </div>
    <div class="about-val">
      <span class="about-val-num">03</span>
      <div class="about-val-ar">الاستمرارية</div>
      <div class="about-val-en">Lasting Impact</div>
      <div class="about-val-desc">The same families, the same land, every season. We build relationships with growers, not just transactions.</div>
    </div>
  </div>
</div>

<!-- Process steps -->
<div class="about-origin">
  <h2 class="about-origin-title">From Source to <em>Your Table</em></h2>
  <div class="about-steps">
    <div class="about-step">
      <div class="about-step-num">01</div>
      <div class="about-step-ar">الاختيار</div>
      <div class="about-step-en">Source Selection</div>
      <div class="about-step-desc">We travel to origin countries to select only the finest harvests — no import brokers, direct from growers.</div>
    </div>
    <div class="about-step">
      <div class="about-step-num">02</div>
      <div class="about-step-ar">الفرز</div>
      <div class="about-step-en">Hand Sorting</div>
      <div class="about-step-desc">Every batch is hand-sorted. Anything that doesn't meet our standard doesn't carry the IRTH name.</div>
    </div>
    <div class="about-step">
      <div class="about-step-num">03</div>
      <div class="about-step-ar">التعبئة</div>
      <div class="about-step-en">Artisan Packaging</div>
      <div class="about-step-desc">Packed in boxes that reflect the weight of what's inside — designed to be gifted, remembered, kept.</div>
    </div>
    <div class="about-step">
      <div class="about-step-num">04</div>
      <div class="about-step-ar">التسليم</div>
      <div class="about-step-en">Delivered to You</div>
      <div class="about-step-desc">Shipped across the Gulf, Egypt, Europe and Africa — with care that the journey doesn't diminish the product.</div>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="about-cta">
  <h2 class="about-cta-title" lang="ar" dir="rtl">ابدأ رحلتك مع الإرث</h2>
  <p class="about-cta-sub">Discover the collection — where every product carries a story.</p>
  <a href="{{ routes.collections_url }}" class="about-cta-btn nav-veil-link">اكتشف المجموعة ↘</a>
</div>

{% schema %}
{
  "name": "About Story",
  "tag": "div",
  "class": "section-about-story",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_title", "label": "Hero title (English)", "default": "Heritage of the Pure" },
    { "type": "textarea", "id": "hero_sub", "label": "Hero subtitle (Arabic)", "default": "إرث ليس مجرد علامة تجارية — إنه التزام بإعادة ما أعطته الأرض بكرم وأمانة." },
    { "type": "header", "content": "Story Section" },
    { "type": "image_picker", "id": "story_image", "label": "Story image" },
    { "type": "textarea", "id": "img_quote", "label": "Image quote (Arabic)" },
    { "type": "text", "id": "story_heading", "label": "Story heading (Arabic)" },
    { "type": "textarea", "id": "story_text_1", "label": "Story paragraph 1 (Arabic)" },
    { "type": "text", "id": "story_quote", "label": "Pull quote (Arabic or English)" },
    { "type": "textarea", "id": "story_text_2", "label": "Story paragraph 2 (Arabic)" },
    { "type": "header", "content": "Numbers" },
    { "type": "text", "id": "num1_val", "label": "Number 1", "default": "12" },
    { "type": "text", "id": "num1_ar", "label": "Label 1 (Arabic)", "default": "منتج فاخر" },
    { "type": "text", "id": "num1_en", "label": "Label 1 (English)", "default": "Premium Products" },
    { "type": "text", "id": "num2_val", "label": "Number 2", "default": "8" },
    { "type": "text", "id": "num2_ar", "label": "Label 2 (Arabic)", "default": "دول مصدر" },
    { "type": "text", "id": "num2_en", "label": "Label 2 (English)", "default": "Countries of Origin" },
    { "type": "text", "id": "num3_val", "label": "Number 3", "default": "100" },
    { "type": "text", "id": "num3_ar", "label": "Label 3 (Arabic)", "default": "طبيعي" },
    { "type": "text", "id": "num3_en", "label": "Label 3 (English)", "default": "Natural & Pure" },
    { "type": "text", "id": "num4_val", "label": "Number 4", "default": "3" },
    { "type": "text", "id": "num4_ar", "label": "Label 4 (Arabic)", "default": "أسواق دولية" },
    { "type": "text", "id": "num4_en", "label": "Label 4 (English)", "default": "Global Markets" },
    { "type": "header", "content": "Values" },
    { "type": "text", "id": "values_title", "label": "Values section title (Arabic)", "default": "ما نؤمن به" }
  ],
  "presets": [{ "name": "About Story", "category": "Page" }]
}
{% endschema %}
