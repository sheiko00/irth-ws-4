<footer id="site-footer" role="contentinfo">
  <div class="footer-inner">

    <div class="footer-logo">
      {%- if settings.logo != blank -%}
        <img
          class="footer-logo-img"
          src="{{ settings.logo | image_url: width: 120 }}"
          alt="{{ shop.name }}"
          width="60"
          height="60"
          loading="lazy"
        >
      {%- else -%}
        <span class="footer-logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </div>

    <div class="footer-cols">

      <div class="footer-col">
        <p class="footer-tagline" lang="ar" dir="rtl">
          {{ section.settings.tagline_ar | default: 'إرث — تمر فاخر من قلب الجزيرة' }}
        </p>
        <p class="footer-tagline footer-tagline--en">
          {{ section.settings.tagline_en | default: 'IRTH — Premium dates from the heart of Arabia' }}
        </p>
      </div>

      <div class="footer-col footer-col--links">
        <h3 class="footer-col-title" lang="ar" dir="rtl">روابط سريعة</h3>
        <ul class="footer-links" role="list">
          <li><a href="{{ routes.collections_url }}" class="footer-link nav-veil-link" lang="ar">المجموعة</a></li>
          <li><a href="{{ routes.root_url }}#values"  class="footer-link" lang="ar">قيمنا</a></li>
          <li><a href="{{ routes.root_url }}#contact" class="footer-link" lang="ar">التواصل</a></li>
          {%- if section.settings.footer_menu != blank -%}
            {%- for link in linklists[section.settings.footer_menu].links -%}
              <li><a href="{{ link.url }}" class="footer-link{% unless link.url == '#' %} nav-veil-link{% endunless %}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>

      <div class="footer-col footer-col--social">
        <h3 class="footer-col-title">Follow</h3>
        <ul class="footer-social" role="list">
          {%- if settings.social_instagram != blank -%}
            <li><a href="{{ settings.social_instagram }}" class="footer-social-link" target="_blank" rel="noopener" aria-label="Instagram">Ig</a></li>
          {%- endif -%}
          {%- if settings.social_linkedin != blank -%}
            <li><a href="{{ settings.social_linkedin }}" class="footer-social-link" target="_blank" rel="noopener" aria-label="LinkedIn">Li</a></li>
          {%- endif -%}
          {%- if settings.social_whatsapp != blank -%}
            <li><a href="{{ settings.social_whatsapp }}" class="footer-social-link" target="_blank" rel="noopener" aria-label="WhatsApp">Wa</a></li>
          {%- endif -%}
          <li><a href="mailto:{{ settings.contact_email | default: 'hello@irth.co' }}" class="footer-social-link" aria-label="Email">✉</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      {%- if section.settings.footer_legal_menu != blank -%}
        <ul class="footer-legal" role="list">
          {%- for link in linklists[section.settings.footer_legal_menu].links -%}
            <li><a href="{{ link.url }}" class="footer-legal-link">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline_ar",
      "label": "Tagline (Arabic)",
      "default": "إرث — تمر فاخر من قلب الجزيرة"
    },
    {
      "type": "text",
      "id": "tagline_en",
      "label": "Tagline (English)",
      "default": "IRTH — Premium dates from the heart of Arabia"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "footer_legal_menu",
      "label": "Legal menu (privacy, terms)"
    }
  ]
}
{% endschema %}
