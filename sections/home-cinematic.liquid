  <button class="e-btn" id="e-enter">ادخل ↘</button>
  <a href="#" class="e-skip" id="e-skip">Enter without audio</a>
</div>

<!-- ── TRANSITION OVERLAY — fullscreen cinematic ── -->
<div id="trans-overlay">
  <!-- Fullscreen landscape video -->
  <video id="trans-vid" playsinline muted preload="auto" aria-hidden="true" poster="{{ 'intro-poster.jpg' | asset_url }}">
    <!-- Intro video: architecture cinematic, no audio. Dual-source after bash compress-media.sh -->
    <source media="(max-width: 768px)" src="{{ 'intro-mobile.webm' | asset_url }}" type="video/webm">
    <source media="(max-width: 768px)" src="{{ 'intro-mobile.mp4' | asset_url }}"  type="video/mp4">
    <source src="{{ 'intro-desktop.webm' | asset_url }}" type="video/webm">
    <source src="{{ 'intro-desktop.mp4' | asset_url }}"  type="video/mp4">
    <source src="{{ 'intro.mp4' | asset_url }}" type="video/mp4">
  </video>
  <!-- Color grade layers -->
  <div class="film-grade"></div>
  <div class="film-lut"></div>
  <!-- Cinematic letterbox bars (2.39:1) -->
  <div class="film-lb-top"></div>
  <div class="film-lb-bot"></div>
  <!-- Arabic title reveal -->
  <div id="film-title">
    <img src="{{ 'logo.svg' | asset_url }}" class="film-logo-img" alt="إرث IRTH" width="64" height="64">
    <div class="film-title-ar">إرث</div>
    <div class="film-title-line"></div>
    <div class="film-title-sub">IRTH · Heritage of the Pure</div>
    <div class="film-tagline">من قلب المدينة · تراث الطيبات</div>
  </div>
  <!-- White flash/cut -->
  <div id="trans-flash"></div>
</div>

<!-- Cinematic letterbox bars -->
<div id="letterbox-top"></div>
<div id="letterbox-bot"></div>

<!-- ── VIDEO HERO ── -->
<div id="video-hero">
  <video id="hero-vid" autoplay muted loop playsinline poster="{{ 'hero-poster.jpg' | asset_url }}">
    <!-- Phase 04 dual-source: webm (VP9) first for Chrome/FF savings, H.264 mp4 for Safari/fallback.
         Browser picks first matching <source>; falls through if a file is missing. -->
    <source media="(max-width: 768px)" src="{{ 'hero-mobile.webm' | asset_url }}" type="video/webm">
    <source media="(max-width: 768px)" src="{{ 'hero-mobile.mp4' | asset_url }}"  type="video/mp4">
    <source src="{{ 'hero-desktop.webm' | asset_url }}" type="video/webm">
    <source src="{{ 'hero-desktop.mp4' | asset_url }}"  type="video/mp4">
    <source src="{{ 'hero.mp4' | asset_url }}" type="video/mp4"><!-- fallback until compression run -->
  </video>
  <div class="video-grade"></div>
  <div class="video-vignette"></div>
  <div class="video-fade-bottom"></div>
</div>
<div id="chroma"></div>

<!-- ── HERO UI ── -->
<div id="hud">
  <div class="h-center">
    <div class="h-eyebrow">From the Heart of Arab Heritage · من قلب الموروث</div>
    <div class="hero-logo-seal" data-anim="seal-mark"><img src="{{ 'logo.svg' | asset_url }}" class="seal-logo-img" alt="إرث" width="64" height="64" loading="eager"></div>
