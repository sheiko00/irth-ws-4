<!-- ── ENTRY ── -->
<div id="entry">
  <div class="eyes">
    <div class="eye">
      <svg class="eye-svg" viewBox="0 0 96 56">
        <!-- almond white -->
        <path class="eye-white" d="M2 28 Q24 4 48 4 Q72 4 94 28 Q72 52 48 52 Q24 52 2 28 Z"/>
        <!-- kohl top heavy line -->
        <path class="eye-kohl" d="M2 28 Q24 4 48 4 Q72 4 94 28"/>
        <!-- kohl bottom light line -->
        <path class="eye-kohl eye-kohl-bot" d="M2 28 Q24 52 48 52 Q72 52 94 28"/>
        <!-- kohl extension (wing) -->
        <path class="eye-kohl" d="M94 28 Q102 26 106 22"/>
        <!-- lashes -->
        <line class="eye-lash" x1="22" y1="6" x2="20" y2="0"/>
        <line class="eye-lash" x1="36" y1="3" x2="35" y2="-3"/>
        <line class="eye-lash" x1="50" y1="2" x2="50" y2="-4"/>
        <line class="eye-lash" x1="64" y1="3" x2="65" y2="-3"/>
        <line class="eye-lash" x1="78" y1="6" x2="80" y2="0"/>
      </svg>
      <div class="pupil" id="pl"></div>
    </div>
    <div class="eye">
      <svg class="eye-svg" viewBox="0 0 96 56">
        <path class="eye-white" d="M2 28 Q24 4 48 4 Q72 4 94 28 Q72 52 48 52 Q24 52 2 28 Z"/>
        <path class="eye-kohl" d="M2 28 Q24 4 48 4 Q72 4 94 28"/>
        <path class="eye-kohl eye-kohl-bot" d="M2 28 Q24 52 48 52 Q72 52 94 28"/>
        <path class="eye-kohl" d="M2 28 Q-6 26 -10 22"/>
        <line class="eye-lash" x1="22" y1="6" x2="20" y2="0"/>
        <line class="eye-lash" x1="36" y1="3" x2="35" y2="-3"/>
        <line class="eye-lash" x1="50" y1="2" x2="50" y2="-4"/>
        <line class="eye-lash" x1="64" y1="3" x2="65" y2="-3"/>
        <line class="eye-lash" x1="78" y1="6" x2="80" y2="0"/>
      </svg>
      <div class="pupil" id="pr"></div>
    </div>
  </div>
  <img src="{{ 'logo.svg' | asset_url }}" alt="إرث IRTH" class="e-logo-img" width="40" height="40" loading="eager">
  <div class="e-desc-ar">طعام راقٍ مستوحى من عمق الموروث العربي، يجمع بين نقاء المكوّن ونبل الأثر.</div>
