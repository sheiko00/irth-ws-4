    <a href="#products" class="h-pill">ابدأ رحلتك مع الإرث ↘</a>
  </div>

  <div class="h-bottom">
    <div class="h-year">©2026</div>
  </div>
</div>

<!-- Ambient track for audio-pill -->
<audio id="amb-track" loop preload="none">
