<header id="site-header" role="banner">
  <nav class="n-inner" aria-label="Main navigation">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="n-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          class="n-logo-img"
          src="{{ section.settings.logo | image_url: width: section.settings.logo_width | times: 2 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          height="{{ section.settings.logo_width }}"
          loading="eager"
        >
      {%- elsif settings.logo != blank -%}
        <img
          class="n-logo-img"
          src="{{ settings.logo | image_url: width: 160 }}"
          alt="{{ shop.name }}"
          width="{{ settings.logo_width | default: 80 }}"
          height="{{ settings.logo_width | default: 80 }}"
          loading="eager"
        >
      {%- else -%}
        <span class="n-logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Nav links {%- endcomment -%}
    <ul class="n-links" role="list">
      {%- if section.settings.main_menu != blank -%}
        {%- for link in linklists[section.settings.main_menu].links -%}
          <li>
            <a
              href="{{ link.url }}"
              class="n-link{% if link.active %} n-link--active{% endif %}{% unless link.url == '#' or link.url == '' %} nav-veil-link{% endunless %}"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      {%- else -%}
        <li><a href="{{ routes.collections_url }}" class="n-link nav-veil-link">المجموعة</a></li>
        <li><a href="{{ routes.root_url }}#values"  class="n-link">القيم</a></li>
        <li><a href="{{ routes.root_url }}#contact" class="n-link">التواصل</a></li>
      {%- endif -%}
    </ul>

    {%- comment -%} CTA {%- endcomment -%}
    <a
      href="mailto:{{ settings.contact_email | default: 'hello@irth.co' }}"
      class="n-cta-btn mag-btn"
      aria-label="Contact us"
    >
      <span lang="ar">تواصل معنا</span>
    </a>

  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (overrides global)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 40,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
