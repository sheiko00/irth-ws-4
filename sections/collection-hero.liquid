<div class="col-hero">
  <div class="col-hero-inner">
    <span class="sec-ey">{{ section.settings.eyebrow | default: 'المجموعة' }}</span>
    <h1 class="col-hero-title" lang="ar" dir="rtl">
      {{ section.settings.title_ar | default: collection.title | default: 'المجموعة الكاملة' }}
    </h1>
    <p class="col-hero-en">
      {{ section.settings.title_en | default: 'The Full Collection' }}
    </p>
    <span class="col-hero-count">
      {%- assign prod_count = collection.products_count | default: 0 -%}
      {%- if prod_count < 10 -%}0{%- endif -%}{{ prod_count }}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "div",
  "class": "section-collection-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title_ar",
      "label": "Title (Arabic) — overrides collection title",
      "info": "Leave blank to use the collection title."
    },
    {
      "type": "text",
      "id": "title_en",
      "label": "Title (English)",
      "default": "The Full Collection"
    }
  ]
}
{% endschema %}
